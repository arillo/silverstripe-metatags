{
    "name": "arillo/silverstripe-metatags",
    "description": "Metatags for SilverStripe",
    "type": "silverstripe-vendormodule",
    "homepage": "https://github.com/arillo/silverstripe-metatags",
    "keywords": ["silverstripe", "metatags", "seo"],
    "license": "MIT",
    "authors": [
        {
            "name": "Daniel Murcia",
            "email": "dm@arillo.net"
        },
        {
            "name": "Sebastian Fischer",
            "email": "sf@arillo.net"
        }
    ],
    "require": {
        "php": "^8.3",
        "silverstripe/vendor-plugin": "^3.0",
        "silverstripe/framework": "^6",
        "silverstripe/cms": "^6.0"
    },
    "autoload": {
        "psr-4": {
            "Arillo\\MetaTags\\": "src/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-master": "3.x-dev"
        }
    },
    "support": {
        "issues": "https://github.com/arillo/silverstripe-metatags/issues"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
